server:
  directory: "/var/lib/unbound"
  username: "unbound"
  port: {{ unbound_listen_port }}

  {% for ifc in unbound_listen_interfaces %}
  interface: {{ ifc }}
  {% endfor %}

  {% for net in unbound_access_control %}
  access-control: {{ net }} allow
  {% endfor %}

  hide-identity: yes
  hide-version: yes
  qname-minimisation: yes

  {% if unbound_zone_name and unbound_zone_vms %}
  {# PTR: reverse lookups for VM IPs #}
  {% for name, vm in unbound_zone_vms.items() %}
  local-data-ptr: "{{ unbound_zone_base_prefix }}.{{ vm.vmid }} {{ name }}.{{ unbound_zone_name }}."
  {% endfor %}
  {% endif %}

auth-zone:
  name: "{{ unbound_zone_name }}."
  zonefile: "{{ unbound_zone_dir }}/{{ unbound_zone_name }}.zone"
  for-downstream: no
  for-upstream: yes

forward-zone:
  name: "."
  {% for dns in unbound_upstream_dns %}
  forward-addr: {{ dns }}
  {% endfor %}
